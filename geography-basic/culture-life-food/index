<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>09 世界の食｜インタラクティブ教材</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/topojson-client/3.1.0/topojson-client.min.js"></script>
<style>
  :root{
    --ink:#1d2433;--sub:#5a6473;--line:#e3e7ec;--panel:#f5f7f9;--paper:#fff;
    --navy:#1f3864;--cha:#2f8f6b;--te:#2b7fc4;--wheat:#d9a300;--maize:#e2711d;--rice:#2f8f6b;--exc:#9b59b6;
    --radius:14px;--shadow:0 1px 3px rgba(20,30,50,.07),0 6px 22px rgba(20,30,50,.06);
  }
  *{box-sizing:border-box}
  body{margin:0;background:linear-gradient(180deg,#eef1f4,#f6f8fa 240px);color:var(--ink);
    font-family:"Hiragino Kaku Gothic ProN","Yu Gothic Medium","Yu Gothic",Meiryo,sans-serif;
    line-height:1.75;-webkit-font-smoothing:antialiased;font-feature-settings:"palt" 1}
  .wrap{max-width:860px;margin:0 auto;padding:0 16px 80px}
  header{padding:28px 0 12px}
  .eyebrow{font-size:12px;letter-spacing:.18em;color:var(--cha);font-weight:700;margin:0 0 6px}
  h1{font-size:25px;margin:0}
  .lede{color:var(--sub);font-size:13.5px;margin:8px 0 0}
  nav{position:sticky;top:0;z-index:20;background:rgba(246,248,250,.93);backdrop-filter:blur(6px);
    margin:14px -16px 0;padding:8px 16px;border-bottom:1px solid var(--line);display:flex;gap:6px;overflow-x:auto}
  nav button{flex:0 0 auto;border:1px solid var(--line);background:#fff;color:var(--sub);
    padding:9px 15px;border-radius:999px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;font-family:inherit;transition:.15s}
  nav button:hover{border-color:var(--navy);color:var(--navy)}
  nav button[aria-selected="true"]{background:var(--navy);color:#fff;border-color:var(--navy)}
  section{display:none;animation:fade .25s ease}
  section.active{display:block}
  @keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .card{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px;margin:18px 0}
  .card h2{font-size:19px;margin:0 0 4px;display:flex;align-items:center;gap:10px}
  .chip{font-size:11px;font-weight:800;letter-spacing:.04em;color:#fff;padding:3px 9px;border-radius:6px;line-height:1.6}
  .q{color:var(--navy);font-weight:700;margin:2px 0 14px;font-size:14.5px}
  p.note{font-size:13px;color:var(--sub);margin:8px 0}
  .mapwrap{position:relative;border:1px solid var(--line);border-radius:12px;overflow:hidden;background:#d9e8f1;min-height:120px}
  svg.map{display:block;width:100%;height:auto}
  .pin text{font-size:12.5px;font-weight:700;pointer-events:none;paint-order:stroke;stroke:#fff;stroke-width:3px}
  .pin{cursor:pointer;transition:opacity .15s}
  .pin.dim{opacity:.22}
  .route{fill:none;stroke-linecap:round;stroke-linejoin:round}
  .maploading{padding:26px;text-align:center;color:var(--sub);font-size:13px}
  .maperr{padding:18px;font-size:13px;color:#8a5a00;background:#fff7e6;border-radius:10px;margin:0}
  .legend{display:flex;gap:16px;flex-wrap:wrap;margin:10px 0 0;font-size:12.5px;color:var(--sub)}
  .legend i{display:inline-block;width:22px;height:4px;border-radius:3px;vertical-align:middle;margin-right:5px}
  .ctrls{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:14px 0 6px}
  .seg{display:inline-flex;border:1px solid var(--line);border-radius:10px;overflow:hidden}
  .seg button{border:none;background:#fff;padding:8px 16px;font-family:inherit;font-weight:700;font-size:13px;cursor:pointer;color:var(--sub)}
  .seg button[data-on="land"][aria-pressed="true"]{background:var(--cha);color:#fff}
  .seg button[data-on="sea"][aria-pressed="true"]{background:var(--te);color:#fff}
  .slider-row{display:flex;align-items:center;gap:12px;margin:10px 0 0}
  input[type=range]{flex:1;accent-color:var(--navy)}
  .info{margin-top:12px;background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:13px 15px;font-size:14px;min-height:46px}
  .info b{font-size:15px}
  .match{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media(max-width:600px){.match{gap:8px}}
  .col h3{font-size:13px;color:var(--sub);margin:0 0 8px;letter-spacing:.04em}
  .tile{display:block;width:100%;text-align:left;border:1px solid var(--line);background:#fff;border-radius:11px;
    padding:11px 13px;margin:0 0 9px;font-family:inherit;font-size:14px;cursor:pointer;transition:.12s;line-height:1.5}
  .tile small{display:block;color:var(--sub);font-size:11.5px;margin-top:2px}
  .tile:hover{border-color:var(--navy)}
  .tile.sel{border-color:var(--maize);box-shadow:inset 0 0 0 1.5px var(--maize);background:#fff7ef}
  .tile.done{cursor:default;opacity:.55;border-style:dashed}
  .tile.done.matched{opacity:1;border-color:var(--cha);background:#eaf3ee;box-shadow:inset 0 0 0 1.5px var(--cha)}
  @keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
  .tile.bad{animation:shake .3s;border-color:#c0392b}
  .progress{font-size:13px;color:var(--sub);margin:6px 0 0}
  .reveal{margin-top:12px;font-size:13.5px;background:#fff7ef;border:1px solid #f0d9b8;border-radius:11px;padding:12px 14px;display:none}
  .reveal.show{display:block}
  .india{display:grid;grid-template-columns:210px 1fr;gap:18px;align-items:start}
  @media(max-width:600px){.india{grid-template-columns:1fr}}
  #indiaMap svg{width:100%;height:auto;border:1px solid var(--line);border-radius:12px;background:#d9e8f1}
  .rainbox{font-size:14px}
  .rainval{font-size:30px;font-weight:800;font-variant-numeric:tabular-nums}
  .gauge{height:14px;border-radius:8px;background:linear-gradient(90deg,#e8c33a,#e8c33a 50%,#2f8f6b 50%,#2f8f6b);position:relative;margin:10px 0 4px}
  .gauge .thr{position:absolute;left:50%;top:-4px;bottom:-4px;width:2px;background:var(--navy)}
  .gauge .mk{position:absolute;top:-7px;width:0;height:0;border:6px solid transparent;border-top-color:var(--navy);transform:translateX(-6px);transition:left .15s}
  .reg{display:inline-block;padding:3px 10px;border-radius:7px;font-weight:800;font-size:13px;color:#fff;margin-bottom:6px;background:#d9a300}
  .foods{font-size:14px;margin:6px 0}.foods b{font-size:15px}
  .curries{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:6px}
  .curry{border:1px solid var(--line);border-radius:12px;padding:13px;background:#fff}
  .curry .nm{font-weight:700;font-size:15px}
  .curry .pick{display:flex;gap:6px;margin:9px 0 0}
  .curry .pick button{flex:1;border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px;font-family:inherit;font-weight:700;cursor:pointer;font-size:14px}
  .curry .pick button.eat[data-on]{background:var(--cha);color:#fff;border-color:var(--cha)}
  .curry .pick button.no[data-on]{background:#c0392b;color:#fff;border-color:#c0392b}
  .curry .res{font-size:12.5px;margin-top:8px;display:none}
  .curry .res.show{display:block}.curry .res.ok{color:var(--cha)}.curry .res.ng{color:#c0392b}
  footer{text-align:center;color:var(--sub);font-size:12px;margin-top:30px}
  @media print{nav{display:none}section{display:block!important}}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <p class="eyebrow">26 地理総合 ／ 第2編1章4節「食」から見る世界</p>
    <h1>09 世界の食 — インタラクティブ教材</h1>
    <p class="lede">クリック・スライドして、自分で操作しながら学ぼう。3つのワークがあります。</p>
  </header>

  <nav id="tabs" role="tablist">
    <button role="tab" aria-selected="true" data-t="t1">① 茶の伝播マップ</button>
    <button role="tab" aria-selected="false" data-t="t2">② 新大陸の作物と料理</button>
    <button role="tab" aria-selected="false" data-t="t3">③ インドのカレーと地理</button>
  </nav>

  <section id="t1" class="active">
    <div class="card">
      <h2><span class="chip" style="background:var(--cha)">ワーク①</span>茶の伝播マップ — 分岐点をさがそう</h2>
      <p class="q">Q. 茶の呼び方が「チャ」系と「テ」系に分かれるのはなぜ？</p>
      <p class="note">茶は<b>中国南部</b>が原産。「陸路」と「海路」のどちらで伝わったかで呼び名が変わりました。下のボタンで経路を選び、<b>スライダー</b>で茶を運んでみよう。地図の<b>ピン</b>をクリックすると呼び名がわかります。</p>
      <div class="mapwrap"><div id="teaMap"><div class="maploading">地図を読み込み中…（オンライン環境が必要です）</div></div></div>
      <div class="legend">
        <span><i style="background:var(--cha)"></i>陸路 → 「チャ」系</span>
        <span><i style="background:var(--te)"></i>海路 → 「テ」系</span>
        <span><i style="background:var(--exc)"></i>例外</span>
      </div>
      <div class="ctrls">
        <div class="seg" role="group" aria-label="経路の選択">
          <button data-on="land" aria-pressed="true" onclick="setRoute('land')">陸路（チャ）</button>
          <button data-on="sea" aria-pressed="false" onclick="setRoute('sea')">海路（テ）</button>
        </div>
        <span style="font-size:12.5px;color:var(--sub)">経路を選んでスライド ↓</span>
      </div>
      <div class="slider-row">
        <span style="font-size:12px;color:var(--sub)">原産地</span>
        <input type="range" id="teaSlide" min="0" max="100" value="0" oninput="moveToken(this.value)">
        <span style="font-size:12px;color:var(--sub)">到達</span>
      </div>
      <div class="info" id="teaInfo">中国（原産）が<b>分岐点</b>。ここから陸路は「チャ」、海路は「テ」へ。ピンをクリックしてみよう。</div>
    </div>
  </section>

  <section id="t2">
    <div class="card">
      <h2><span class="chip" style="background:var(--maize)">ワーク②</span>新大陸の作物と、世界の有名料理</h2>
      <p class="q">Q. 世界の「伝統料理」は、いつ・どこから来た作物で作られている？</p>
      <p class="note">下の料理は、どれも<b>大航海時代（15世紀末〜）に新大陸（南北アメリカ）からもたらされた作物</b>で作られています。<b>左の作物をクリック → 右の料理をクリック</b>して正しく組み合わせよう。</p>
      <div class="match">
        <div class="col"><h3>新大陸原産の作物</h3><div id="crops"></div></div>
        <div class="col"><h3>その作物で有名な料理（国）</h3><div id="dishes"></div></div>
      </div>
      <p class="progress" id="matchProg">0 / 5 組</p>
      <div class="reveal" id="matchReveal"></div>
    </div>
  </section>

  <section id="t3">
    <div class="card">
      <h2><span class="chip" style="background:var(--rice)">ワーク③</span>インドのカレーと地理</h2>
      <p class="q">Q. 同じインドでも、地域で主食が、宗教で食材が変わるのはなぜ？</p>
      <p class="note">スライダーで<b>年間降水量</b>を動かそう。<b>1000mm</b>を境に、主食とカレーに合わせる主食が変わります。</p>
      <div class="india">
        <div id="indiaMap"><div class="maploading">地図を読み込み中…</div></div>
        <div class="rainbox">
          <span class="reg" id="regTag">畑作地域</span>
          <div><span class="rainval" id="rainVal">800</span> <span style="color:var(--sub)">mm／年</span></div>
          <div class="gauge"><div class="thr"></div><div class="mk" id="rainMk" style="left:40%"></div></div>
          <div style="font-size:11px;color:var(--sub);display:flex;justify-content:space-between"><span>0</span><span>1000mm（境）</span><span>2000</span></div>
          <input type="range" id="rainSlide" min="0" max="2000" step="50" value="800" oninput="setRain(this.value)" style="width:100%;margin-top:8px">
          <div class="foods" id="foodOut"></div>
          <p style="font-size:11.5px;color:var(--sub);margin:4px 0 0">※ナンはタンドール窯が必要で、家庭ではあまり食べられない。</p>
        </div>
      </div>
    </div>

    <div class="card">
      <h2><span class="chip" style="background:var(--navy)">食材</span>このカレー、インドで一般的？</h2>
      <p class="note">インドは<b>ヒンドゥー教徒が多数</b>。各カレーを「食べる」「食べない」で予想してクリックしよう。</p>
      <div class="curries" id="curries"></div>
      <div class="reveal show" style="background:#eef3fb;border-color:#cdd9ee;margin-top:14px;color:var(--navy)">
        <b>ポイント：</b>ヒンドゥー教では牛を神聖視 → 牛肉を食べない。不殺生の考えから<b>菜食主義者(ベジタリアン)も多く</b>、豆や野菜のカレーが主流。だから<b>ビーフカレーはほぼ存在しない。</b>
      </div>
    </div>
  </section>

  <footer>26地理総合 09 世界の衣食住～食～ ／ 地図は Natural Earth データ（D3）で描画。入力は保存されません</footer>
</div>

<script>
/* ===== tabs ===== */
const tabs=document.getElementById('tabs');
tabs.addEventListener('click',e=>{const b=e.target.closest('button');if(!b)return;
  [...tabs.children].forEach(x=>x.setAttribute('aria-selected',x===b));
  document.querySelectorAll('section').forEach(s=>s.classList.toggle('active',s.id===b.dataset.t));
  window.scrollTo({top:0,behavior:'smooth'});});

/* ===== ① TEA (D3 accurate map) ===== */
const COL={origin:'#3a4250',land:'#2f8f6b',sea:'#2b7fc4',exception:'#9b59b6'};
const TXT={origin:'#3a4250',land:'#1e6b4f',sea:'#1f5e94',exception:'#7d3c98'};
const PINS=[
  {n:'中国（原産）',lon:113,lat:30,r:'origin',w:'chá ／ チャ',note:'茶の原産地。ここが<b>分岐点</b>。陸路は「チャ」、海路は「テ」に分かれた。'},
  {n:'インド',lon:78,lat:22,r:'land',w:'チャイ (chai)',note:'陸路で伝わったため「チャ」系。'},
  {n:'ロシア',lon:38,lat:56,r:'land',w:'чай (チャイ)',note:'陸路（シルクロード）で伝わったため「チャ」系。'},
  {n:'トルコ',lon:33,lat:39,r:'land',w:'çay (チャイ)',note:'陸路で伝わったため「チャ」系。'},
  {n:'日本',lon:138,lat:37,r:'land',w:'チャ',note:'大陸から伝わったため「チャ」系。'},
  {n:'インドネシア',lon:110,lat:-2,r:'sea',w:'teh (テ)',note:'海路で伝わったため「テ」系。'},
  {n:'イギリス',lon:-1,lat:52,r:'sea',w:'tea (ティー)',note:'海路（オランダ商人など）で伝わったため「テ」系。'},
  {n:'フランス',lon:2,lat:47,r:'sea',w:'thé (テ)',note:'海路で伝わったため「テ」系。'},
  {n:'ポルトガル',lon:-8,lat:39,r:'exception',w:'chá (シャ)',note:'<b>例外！</b> 海路だが、マカオ経由で伝わったため「チャ」系。'},
];
const LAND=[[113,29],[100,40],[80,42],[62,43],[48,42],[40,41],[34,39]];
const SPUR_RU=[[55,45],[46,50],[39,55]];
const SPUR_IN=[[95,33],[85,27],[78,23]];
const SEA=[[118,25],[112,8],[101,2],[85,4],[66,1],[50,-8],[38,-18],[22,-34],[8,-29],[-3,-2],[-12,18],[-14,33],[-11,40],[-3,46],[1,50]];

let routeLand,routeSea,token,activeRoute='land';
const TEA_W=960,TEA_H=560;

async function loadWorld(){
  const urls=['https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json',
              'https://unpkg.com/world-atlas@2/countries-110m.json'];
  for(const u of urls){try{return await d3.json(u);}catch(e){}}
  throw new Error('world data unavailable');
}
function buildTea(world){
  const svg=d3.select('#teaMap').html('').append('svg').attr('class','map').attr('viewBox',`0 0 ${TEA_W} ${TEA_H}`);
  svg.append('rect').attr('width',TEA_W).attr('height',TEA_H).attr('fill','#d9e8f1');
  // ring wound clockwise so d3 crops to this region (not the whole globe)
  const region={type:'Polygon',coordinates:[[[-26,-40],[-26,76],[152,76],[152,-40],[-26,-40]]]};
  const proj=d3.geoNaturalEarth1().fitExtent([[6,6],[TEA_W-6,TEA_H-6]],region);
  const path=d3.geoPath(proj);
  const land=topojson.feature(world,world.objects.countries);
  svg.append('g').selectAll('path').data(land.features).join('path')
     .attr('d',path).attr('fill','#e7e1d2').attr('stroke','#cdbfa0').attr('stroke-width',.6);
  svg.append('path').datum(d3.geoGraticule10()).attr('d',path)
     .attr('fill','none').attr('stroke','#fff').attr('stroke-opacity',.35).attr('stroke-width',.6);
  const mk=c=>path({type:'Feature',geometry:{type:'LineString',coordinates:c}});
  svg.append('path').attr('d',mk(SPUR_RU)).attr('class','spur land').attr('stroke','#2f8f6b').attr('stroke-width',2).attr('fill','none').attr('opacity',.75);
  svg.append('path').attr('d',mk(SPUR_IN)).attr('class','spur land').attr('stroke','#2f8f6b').attr('stroke-width',2).attr('fill','none').attr('opacity',.75);
  routeLand=svg.append('path').attr('d',mk(LAND)).attr('class','route routeLand').attr('stroke','#2f8f6b').attr('stroke-width',3.2).node();
  routeSea=svg.append('path').attr('d',mk(SEA)).attr('class','route routeSea').attr('stroke','#2b7fc4').attr('stroke-width',3.2).attr('stroke-dasharray','2 7').node();
  const pg=svg.append('g');
  PINS.forEach((p,i)=>{
    const xy=proj([p.lon,p.lat]); if(!xy)return; const x=xy[0],y=xy[1];
    const g=pg.append('g').attr('class','pin').attr('data-r',p.r).on('click',()=>showPin(i));
    g.append('circle').attr('cx',x).attr('cy',y).attr('r',p.r==='origin'?7:5.5)
      .attr('fill',COL[p.r]).attr('stroke','#fff').attr('stroke-width',2);
    const left=x>TEA_W*.8;
    g.append('text').attr('x',x+(left?-9:9)).attr('y',y+3.5)
      .attr('text-anchor',left?'end':'start').attr('fill',TXT[p.r]).text(p.n);
  });
  token=svg.append('text').attr('font-size',22).attr('text-anchor','middle')
    .attr('dominant-baseline','central').style('display','none').text('🍵').node();
  setRoute('land');
}
function showPin(i){const p=PINS[i];document.getElementById('teaInfo').innerHTML=`<b>${p.n}</b> ：「${p.w}」<br>${p.note}`;}
function setRoute(r){
  activeRoute=r;
  document.querySelectorAll('.seg button').forEach(b=>b.setAttribute('aria-pressed',b.dataset.on===r));
  if(!routeLand)return;
  document.querySelectorAll('#teaMap .pin').forEach(g=>{
    const pr=g.getAttribute('data-r');
    const on=(r==='land')?(pr==='land'||pr==='origin'):(pr==='sea'||pr==='origin'||pr==='exception');
    g.classList.toggle('dim',!on);
  });
  document.querySelectorAll('#teaMap .spur').forEach(s=>s.style.opacity=(r==='land')?.75:.12);
  const other=r==='land'?routeSea:routeLand;
  other.style.opacity=.18;
  if(r==='land'){
    const L=routeLand.getTotalLength();
    routeLand.style.strokeDasharray=L;routeLand.style.strokeDashoffset=L;routeLand.style.transition='none';routeLand.style.opacity=1;
    requestAnimationFrame(()=>{routeLand.style.transition='stroke-dashoffset 1s ease';routeLand.style.strokeDashoffset=0;});
  }else{
    routeSea.style.strokeDasharray='2 7';routeSea.style.strokeDashoffset=0;routeSea.style.opacity=1;
  }
  document.getElementById('teaSlide').value=0;moveToken(0);
  document.getElementById('teaInfo').innerHTML = r==='land'
    ? '<b>陸路</b>を選択。シルクロードなど陸の道で内陸へ伝わった地域は「チャ」系（中国・インド・ロシア・トルコ・日本）。'
    : '<b>海路</b>を選択。船で運ばれた地域は「テ」系（インドネシア・イギリス・フランス）。※ポルトガルは海路でも例外的に「チャ」。';
}
function moveToken(v){
  if(!token)return;
  const path=activeRoute==='land'?routeLand:routeSea;
  const L=path.getTotalLength();const pt=path.getPointAtLength(L*v/100);
  token.setAttribute('x',pt.x);token.setAttribute('y',pt.y);token.style.display='block';
}

/* ===== ② MATCHING ===== */
const PAIRS=[
  {crop:'ジャガイモ',origin:'アンデス原産',dish:'フライドポテト',country:'ベルギー',fact:'ジャガイモはアンデス高地が原産。冷涼でやせた土地でも育ち、ヨーロッパ北部に広まった。'},
  {crop:'トウガラシ',origin:'中南米原産',dish:'辛いキムチ',country:'韓国',fact:'トウガラシは中南米原産。大航海時代に伝わり、いまや韓国料理に欠かせない。'},
  {crop:'トマト',origin:'アンデス〜中米原産',dish:'トマトパスタ',country:'イタリア',fact:'トマトは新大陸原産。イタリア料理の象徴だが、伝わったのは大航海時代以降。'},
  {crop:'トウモロコシ',origin:'中米原産',dish:'タコス',country:'メキシコ',fact:'トウモロコシは中米原産。すりつぶして薄焼きにしたトルティーヤがタコスになる。'},
  {crop:'カカオ',origin:'中米原産',dish:'チョコレート',country:'スイス',fact:'カカオは中米原産。ヨーロッパに伝わり、スイスやベルギーが名産地になった。'},
];
let selCrop=null,matched=0;
const cropsEl=document.getElementById('crops'),dishesEl=document.getElementById('dishes');
PAIRS.forEach((p,i)=>{const b=document.createElement('button');b.className='tile';b.dataset.i=i;
  b.innerHTML=`${p.crop}<small>${p.origin}</small>`;
  b.onclick=()=>{if(b.classList.contains('done'))return;
    document.querySelectorAll('#crops .tile').forEach(t=>t.classList.remove('sel'));
    b.classList.add('sel');selCrop=i;};cropsEl.appendChild(b);});
[...PAIRS.keys()].sort(()=>Math.random()-.5).forEach(i=>{const p=PAIRS[i];
  const b=document.createElement('button');b.className='tile';b.dataset.i=i;
  b.innerHTML=`${p.dish}<small>${p.country}</small>`;b.onclick=()=>tryMatch(b,i);dishesEl.appendChild(b);});
function tryMatch(dishBtn,i){
  if(dishBtn.classList.contains('done'))return;
  if(selCrop===null){flash(dishBtn);return;}
  if(selCrop===i){
    const cropBtn=document.querySelector(`#crops .tile[data-i="${i}"]`);
    [cropBtn,dishBtn].forEach(b=>{b.classList.remove('sel');b.classList.add('done','matched');});
    matched++;selCrop=null;document.getElementById('matchProg').textContent=`${matched} / 5 組`;
    appendReveal(PAIRS[i]);
    if(matched===5)document.getElementById('matchProg').textContent='5 / 5 組 ぜんぶ正解！ どれも新大陸の作物だね。';
  }else{flash(dishBtn);}
}
function flash(b){b.classList.add('bad');setTimeout(()=>b.classList.remove('bad'),320);}
function appendReveal(p){const r=document.getElementById('matchReveal');r.classList.add('show');
  const line=document.createElement('div');line.style.margin='4px 0';
  line.innerHTML=`<b>${p.crop}（${p.origin}）→ ${p.dish}（${p.country}）</b>　${p.fact}`;r.appendChild(line);}

/* ===== ③ INDIA (D3 accurate outline) ===== */
let indiaShape,indiaDot,NW,SE;
function buildIndia(world){
  const india=topojson.feature(world,world.objects.countries).features.find(f=>String(f.id)==='356');
  if(!india){document.getElementById('indiaMap').innerHTML='<p class="maperr">インドの地図データを取得できませんでした。</p>';return;}
  const W=210,H=250;
  const svg=d3.select('#indiaMap').html('').append('svg').attr('viewBox',`0 0 ${W} ${H}`);
  svg.append('rect').attr('width',W).attr('height',H).attr('fill','#d9e8f1');
  const proj=d3.geoMercator().fitExtent([[14,14],[W-14,H-14]],india);
  const path=d3.geoPath(proj);
  indiaShape=svg.append('path').attr('d',path(india)).attr('fill','#d9a300').attr('stroke','#b9893f').attr('stroke-width',1).node();
  NW=proj([74.5,30.5]); SE=proj([79.5,12]);
  svg.append('text').attr('x',NW[0]-2).attr('y',NW[1]-10).attr('font-size',10).attr('fill','#6b7280').attr('text-anchor','middle').text('北西部');
  svg.append('text').attr('x',SE[0]).attr('y',SE[1]+18).attr('font-size',10).attr('fill','#6b7280').attr('text-anchor','middle').text('南東部');
  indiaDot=svg.append('circle').attr('r',6).attr('fill','#fff').attr('stroke','#1f3864').attr('stroke-width',2.5).node();
  setRain(document.getElementById('rainSlide').value);
}
function setRain(v){
  v=+v;
  document.getElementById('rainVal').textContent=v;
  document.getElementById('rainMk').style.left=(v/2000*100)+'%';
  const wheat=v<1000;
  const tag=document.getElementById('regTag'),out=document.getElementById('foodOut');
  if(wheat){
    if(indiaShape){indiaShape.setAttribute('fill','#d9a300');indiaShape.setAttribute('stroke','#b9893f');}
    if(indiaDot&&NW){indiaDot.setAttribute('cx',NW[0]);indiaDot.setAttribute('cy',NW[1]);}
    tag.textContent='畑作地域（北西部）';tag.style.background='#d9a300';
    out.innerHTML='主食：<b>小麦</b>（年降水量1000mm未満）<br>カレーに合わせる主食：<b>チャパティ</b>（薄焼きパン）・<b>プーリー</b>（揚げパン）';
  }else{
    if(indiaShape){indiaShape.setAttribute('fill','#2f8f6b');indiaShape.setAttribute('stroke','#1e6b4f');}
    if(indiaDot&&SE){indiaDot.setAttribute('cx',SE[0]);indiaDot.setAttribute('cy',SE[1]);}
    tag.textContent='稲作地域（南東部）';tag.style.background='#2f8f6b';
    out.innerHTML='主食：<b>米</b>（年降水量1000mm以上）<br>カレーに合わせる主食：<b>ドサ</b>（米のクレープ）・<b>チャワル</b>（炊いた米）';
  }
}
setRain(800);

/* ===== curry quiz ===== */
const CURRIES=[
  {nm:'🐄 ビーフカレー',eat:false,note:'牛は神聖な動物。ヒンドゥー教徒は牛肉を食べないため、ほぼ存在しない。'},
  {nm:'🐓 チキンカレー',eat:true,note:'鶏肉はよく食べられ、定番のカレー。'},
  {nm:'🐑 マトンカレー',eat:true,note:'羊・ヤギの肉はよく使われる。'},
  {nm:'🫘 豆・野菜カレー（ダル）',eat:true,note:'菜食主義者が多く、もっとも主流。'},
];
const curBox=document.getElementById('curries');
CURRIES.forEach((c,i)=>{const d=document.createElement('div');d.className='curry';
  d.innerHTML=`<div class="nm">${c.nm}</div>
    <div class="pick"><button class="eat" onclick="answerCurry(${i},true,this)">食べる</button>
    <button class="no" onclick="answerCurry(${i},false,this)">食べない</button></div>
    <div class="res" id="cr${i}"></div>`;curBox.appendChild(d);});
const answered=[];
function answerCurry(i,choice,btn){
  if(answered[i])return;answered[i]=true;
  btn.parentNode.querySelectorAll('button').forEach(b=>b.removeAttribute('data-on'));
  btn.setAttribute('data-on','');
  const ok=(choice===CURRIES[i].eat);const r=document.getElementById('cr'+i);
  r.className='res show '+(ok?'ok':'ng');
  r.innerHTML=(ok?'◯ 正解！ ':'× 残念… ')+CURRIES[i].note;
}

/* ===== init maps ===== */
(async function(){
  if(typeof d3==='undefined'||typeof topojson==='undefined'){showMapError();return;}
  try{const world=await loadWorld();buildTea(world);buildIndia(world);}
  catch(e){showMapError();}
})();
function showMapError(){
  const msg='<p class="maperr">正確な地図データ（Natural Earth）の読み込みにインターネット接続が必要です。学校のネットワークなどオンライン環境で開いてください。地図以外のワークはそのまま使えます。</p>';
  const tm=document.getElementById('teaMap'),im=document.getElementById('indiaMap');
  if(tm)tm.innerHTML=msg; if(im)im.innerHTML=msg;
}
